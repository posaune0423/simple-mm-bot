# -----------------------------------------------------------------------------
# Bot runtime settings
# These values control how the bot itself starts and where it reads config/data.
# -----------------------------------------------------------------------------

# Path to the committed YAML config file to load at startup.
CONFIG_PATH=config/config.yml

# Runtime mode for the bot.
# Allowed values: live | paper | backtest
MODE=paper

# Local SQLite path used when DATABASE_URL is not set.
DB_PATH=data/mmbot.db

# Optional PostgreSQL DSN.
# If set, the bot uses Postgres repositories instead of SQLite.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Venue-specific settings: Hyperliquid
# These are only needed because the current venue adapter targets Hyperliquid.
# -----------------------------------------------------------------------------

# Hyperliquid public WebSocket endpoint used for market data subscriptions.
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# Hyperliquid HTTP endpoint used for info/order requests.
HL_HTTP_URL=https://api.hyperliquid.xyz

# Private key used only for live order placement.
# Leave empty for paper/backtest mode.
HL_SECRET_KEY=

# Optional account address used for margin/fill polling.
# If omitted, the live gateway derives it from HL_SECRET_KEY when possible.
HL_ACCOUNT_ADDRESS=
