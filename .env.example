# -----------------------------------------------------------------------------
# Bot runtime settings
# These values control how the bot itself starts and where it reads config/data.
# -----------------------------------------------------------------------------

# Path to the committed YAML config file to load at startup.
CONFIG_PATH=config/config.bulk.beta.yml

# Runtime mode for the bot.
# Allowed values: live | paper | backtest
MODE=paper

# Local SQLite path used when DATABASE_URL is not set.
DB_PATH=data/mm.db

# Optional PostgreSQL DSN.
# If set, the bot uses Postgres repositories instead of SQLite.
DATABASE_URL=

# Log level.
LOG_LEVEL=DEBUG

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/hoge

# -----------------------------------------------------------------------------
# Venue-specific settings: Bulk Trade
# -----------------------------------------------------------------------------

# Private key used only for live Bulk order placement.
# Leave empty for paper mode. Bulk HTTP/WS endpoints and market live in YAML config.
BULK_PRIVATE_KEY=

# if you want to use agent wallet, you need to set these two keys
BULK_PRIMARY_WALLET_PUBLIC_KEY=
BULK_AGENT_WALLET_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# Venue-specific settings: Hyperliquid
# Kept for the temporary backtest path and legacy adapter tests.
# -----------------------------------------------------------------------------

HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_HTTP_URL=https://api.hyperliquid.xyz
HL_SECRET_KEY=
HL_ACCOUNT_ADDRESS=
