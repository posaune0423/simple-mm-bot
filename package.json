{
  "name": "simple-mm-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "CONFIG_PATH= CONFIG_VENUE=bulk CONFIG_PRESET=beta MODE=live bun run src/main.ts",
    "bulk:preflight": "bun run scripts/checkBulkPrivateApi.ts",
    "dev:paper": "CONFIG_PATH= CONFIG_VENUE=bulk CONFIG_PRESET=beta MODE=paper bun run src/main.ts",
    "dev:backtest": "CONFIG_PATH= CONFIG_VENUE=bulk CONFIG_PRESET=beta MODE=backtest bun run src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "bun run lint:code",
    "lint:code": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "loop:backtest-paper": "bun run scripts/backtestPaperLoop.ts",
    "metrics:evaluate": "bun run scripts/evaluateLiveRun.ts",
    "metrics:tune": "bun run scripts/tuneBulkConfig.ts",
    "metrics:issues": "bun run scripts/createDesignIssues.ts",
    "metrics:report": "bun run scripts/generateMetricsReport.ts",
    "report:generate": "bun run scripts/generateReport.ts",
    "analyze:lead-lag": "bun run scripts/analyzeLeadLagCharts.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e:paper": "bun test tests/e2e",
    "test:coverage": "bun test --coverage tests/unit tests/integration && bun run scripts/generateCoverageSummary.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@nktkas/hyperliquid": "^0.32.2",
    "@t3-oss/env-core": "^0.13.11",
    "bulk-ts-sdk": "^0.0.10",
    "drizzle-orm": "^0.44.7",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.9",
    "valibot": "^1.4.0",
    "viem": "^2.48.8",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.20"
  }
}
